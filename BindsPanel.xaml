<UserControl x:Class="HachBobAI.UI.BindsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#0A0A1A" BorderBrush="#2A2A55" BorderThickness="1" CornerRadius="6" Padding="16,12">
        <StackPanel>
            <TextBlock Text="Нажми кнопку — затем нажми нужную клавишу / кнопку мыши"
                       Foreground="#555555" FontSize="11" Margin="0,0,0,10"/>
            <StackPanel x:Name="PART_Rows"/>
            <TextBlock Text="x1/x2 = боковые кнопки мыши  |  lmb = левая  |  rmb = правая"
                       Foreground="#333333" FontSize="10" Margin="0,8,0,0"/>
        </StackPanel>
    </Border>
</UserControl>

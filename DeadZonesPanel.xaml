<UserControl x:Class="HachBobAI.UI.DeadZonesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#150A0A" BorderBrush="#3D1010" BorderThickness="1" CornerRadius="6" Padding="12,10">
        <StackPanel>
            <!-- Вкладки групп -->
            <WrapPanel x:Name="PART_Groups" Margin="0,0,0,8"/>
            <!-- Зоны активной группы -->
            <StackPanel x:Name="PART_List"/>
            <Button Content="+ Добавить зону" Click="AddZone_Click"
                    Width="140" Height="30" HorizontalAlignment="Left" Margin="0,8,0,0"
                    Background="#3A1010" Foreground="#FF6666"
                    BorderBrush="#FF3300" BorderThickness="1" FontSize="12"/>
        </StackPanel>
    </Border>
</UserControl>
